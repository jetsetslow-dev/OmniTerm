<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!--
      Foreground service keeps user-initiated SSH sessions alive in the background. We use the
      `connectedDevice` type because the service exists solely to maintain an interactive connection
      to a remote host the user explicitly connected to.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <!-- Android 14+ requires a connectedDevice runtime prerequisite before startForeground().
         This normal permission represents the app's user-initiated network connection lifecycle. -->
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!--
      No storage permissions: all file access goes through the Storage Access Framework
      (ACTION_OPEN_DOCUMENT / ACTION_CREATE_DOCUMENT pickers), which grants per-file access without
      any permission. This keeps the app compliant with Google Play's scoped-storage policy and
      avoids the heavily-restricted MANAGE_EXTERNAL_STORAGE (All Files Access).
    -->

    <!-- Crash-report issue links resolve only web browsers; declare that narrow visibility query
         instead of requesting visibility into installed packages. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication"
        android:usesCleartextTraffic="false">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.MyApplication">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".SessionService"
            android:foregroundServiceType="connectedDevice"
            android:exported="false" />

        <!-- Shares the saved crash report as a file attachment via the Android share sheet.
             Authority is per-flavor (${applicationId}) so the openSource/playStore builds don't
             collide. Only the app's private crash-report cache dir is exposed. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
